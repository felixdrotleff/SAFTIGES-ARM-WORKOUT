<link rel="manifest" href='data:application/json,{"name":"Saftiges%20Arm-Workout","short_name":"Arm-Workout","display":"standalone","background_color":"%23111210","theme_color":"%23111210"}'>
<title>Saftiges Arm-Workout</title>
<style>
@font-face{font-family:'Anton';src:url(data:font/woff2;base64,) format('woff2');font-weight:400;font-display:swap;}
:root{
  --bg:#111210;--panel:#1b1d16;--panel2:#23261c;--ink:#f3f2e6;--muted:#9b9d8b;
  --line:#33372a;--accent:#c8ff3c;--accent-dim:#7d8f3a;--warn:#ff7a45;
}
*{box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
html,body{margin:0;padding:0;background:var(--bg);color:var(--ink);}
body{
  font-family:-apple-system,BlinkMacSystemFont,"SF Pro Text","Segoe UI",system-ui,sans-serif;
  font-size:16px;line-height:1.5;
  background:radial-gradient(1200px 480px at 50% -10%,rgba(200,255,60,.10),transparent 60%),var(--bg);
  min-height:100vh;padding:0 0 178px;
}
.wrap{max-width:560px;margin:0 auto;padding:0 16px;}
.disp{font-family:'Anton',Impact,sans-serif;letter-spacing:.5px;line-height:.96;text-transform:uppercase;}
header{padding:26px 0 14px;}
.kicker{font-size:11.5px;letter-spacing:.22em;text-transform:uppercase;color:var(--accent-dim);font-weight:700;}
h1.disp{font-size:clamp(40px,12vw,62px);margin:6px 0 4px;}
h1 .juice{color:var(--accent);}
.byline{color:var(--muted);font-size:13.5px;}
.byline b{color:var(--ink);}
.progwrap{position:sticky;top:0;z-index:30;margin:14px 0 10px;padding:12px 14px;
  border:1px solid var(--line);border-radius:16px;background:rgba(27,29,22,.86);
  backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px);}
.progtop{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:9px;}
.progtop .lab{font-size:12px;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);}
.progtop .cnt{font-family:'Anton',sans-serif;font-size:22px;}
.progtop .cnt span{color:var(--accent);}
.bar{height:9px;border-radius:99px;background:#2a2d22;overflow:hidden;}
.bar>i{display:block;height:100%;width:0;border-radius:99px;
  background:linear-gradient(90deg,var(--accent-dim),var(--accent));transition:width .35s cubic-bezier(.2,.8,.2,1);}
.card{border:1px solid var(--line);border-radius:20px;background:var(--panel);margin:14px 0;overflow:hidden;transition:border-color .3s;}
.card.done{border-color:var(--accent-dim);}
.chead{display:flex;gap:14px;align-items:center;padding:16px 16px 12px;}
.badge{flex:0 0 auto;width:104px;height:104px;border-radius:16px;overflow:hidden;
  background:#181a13;border:1px solid var(--line);}
.badge canvas{width:100%;height:100%;display:block;}
.titleblock{flex:1 1 auto;min-width:0;}
.exno{font-family:'Anton',sans-serif;font-size:13px;color:var(--accent-dim);letter-spacing:.1em;}
.exname{font-family:'Anton',sans-serif;font-size:23px;line-height:1;margin:2px 0 7px;text-transform:uppercase;}
.chip{display:inline-block;font-size:11px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;
  color:var(--accent);background:rgba(200,255,60,.10);border:1px solid rgba(200,255,60,.30);padding:3px 9px;border-radius:99px;}
.equip{padding:0 16px;color:var(--muted);font-size:13.5px;font-style:italic;margin:-2px 0 12px;}
.tips{list-style:none;margin:0;padding:0 16px 14px;}
.tips li{position:relative;padding:5px 0 5px 20px;font-size:14.5px;color:#dedfd0;border-top:1px solid rgba(255,255,255,.04);}
.tips li:first-child{border-top:none;}
.tips li::before{content:"";position:absolute;left:2px;top:12px;width:7px;height:7px;border-radius:2px;background:var(--accent);transform:rotate(45deg);}
.tips li.warn{color:var(--warn);font-weight:600;}
.tips li.warn::before{background:var(--warn);}
.sets{display:flex;flex-wrap:wrap;gap:9px;padding:4px 16px 18px;}
.setbtn{flex:1 1 0;min-width:78px;min-height:50px;border-radius:13px;cursor:pointer;
  border:1.5px solid var(--line);background:var(--panel2);color:var(--ink);
  font-family:'Anton',sans-serif;font-size:15px;letter-spacing:.04em;text-transform:uppercase;
  display:flex;align-items:center;justify-content:center;gap:8px;user-select:none;
  transition:transform .08s,background .2s,border-color .2s,color .2s;}
.setbtn .tick{width:16px;height:16px;flex:0 0 auto;}
.setbtn .tick path{stroke:var(--muted);stroke-width:3;fill:none;stroke-dasharray:24;stroke-dashoffset:24;transition:stroke-dashoffset .3s,stroke .2s;}
.setbtn:active{transform:scale(.95);}
.setbtn.on{background:var(--accent);border-color:var(--accent);color:#15170f;}
.setbtn.on .tick path{stroke:#15170f;stroke-dashoffset:0;}
.donebar{display:none;align-items:center;gap:8px;padding:0 16px 16px;color:var(--accent);font-size:13px;font-weight:600;}
.card.done .donebar{display:flex;}
.finish{display:none;margin:18px 0;padding:22px;border-radius:20px;text-align:center;background:linear-gradient(135deg,var(--accent),#9fe015);color:#15170f;}
.finish.show{display:block;animation:pop .4s ease;}
.finish .t{font-family:'Anton',sans-serif;font-size:30px;text-transform:uppercase;}
.finish .s{font-size:14px;font-weight:600;opacity:.85;margin-top:4px;}
@keyframes pop{from{transform:scale(.9);opacity:0}to{transform:scale(1);opacity:1}}
.footnote{color:var(--muted);font-size:12px;text-align:center;margin:22px 4px 8px;line-height:1.6;}
.reset{display:block;margin:10px auto 0;background:none;border:1px solid var(--line);color:var(--muted);
  font-size:12.5px;padding:9px 16px;border-radius:99px;cursor:pointer;letter-spacing:.04em;}
.reset:active{transform:scale(.97);}
.tools{display:flex;gap:8px;justify-content:center;margin-top:8px;flex-wrap:wrap;}
.tbtn2{background:none;border:1px solid var(--line);color:var(--muted);font-size:12.5px;padding:9px 16px;border-radius:99px;cursor:pointer;letter-spacing:.04em;}
.tbtn2:active{transform:scale(.97);}
/* rest timer dock - compact, fits all phones */
.dock{position:fixed;left:0;right:0;bottom:0;z-index:40;
  background:linear-gradient(0deg,var(--bg) 60%,transparent);
  padding:10px 12px calc(12px + env(safe-area-inset-bottom));}
.dockinner{max-width:560px;margin:0 auto;display:flex;flex-direction:column;gap:8px;
  border:1px solid var(--line);border-radius:16px;background:rgba(27,29,22,.94);
  backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px);padding:10px 12px;}
.trow{display:flex;align-items:center;gap:10px;}
.tlab{font-size:10.5px;letter-spacing:.16em;text-transform:uppercase;color:var(--muted);flex:1;}
.timeval{font-family:'Anton',sans-serif;font-size:30px;min-width:78px;text-align:left;letter-spacing:.02em;}
.timeval.run{color:var(--accent);}
.tbtn{border:1.5px solid var(--line);background:var(--panel2);color:var(--ink);border-radius:12px;
  font-family:'Anton',sans-serif;letter-spacing:.05em;text-transform:uppercase;cursor:pointer;}
.tbtn:active{transform:scale(.95);}
.tmain{padding:12px 20px;font-size:15px;flex:0 0 auto;}
.tmain.primary{background:var(--accent);border-color:var(--accent);color:#15170f;}
.tpreset{display:flex;gap:8px;}
.tpreset .tbtn{flex:1 1 0;padding:11px 0;font-size:13px;text-align:center;}
.tpreset .tbtn.sel{border-color:var(--accent);color:var(--accent);}
</style>
</head>
<body>
<div class="wrap">
  <header>
    <div class="kicker">Personal Training · Robin Vizitiu</div>
    <h1 class="disp">Saftiges<br><span class="juice">Arm-Workout</span></h1>
    <div class="byline">Plan von <b>Robin</b> · Sätze antippen zum Abhaken · Tipps bleiben sichtbar</div>
  </header>
  <div class="progwrap">
    <div class="progtop"><div class="lab">Fortschritt</div>
      <div class="cnt"><span id="pdone">0</span> / <span id="ptot">0</span> Sätze</div></div>
    <div class="bar"><i id="pfill"></i></div>
  </div>
  <div id="finish" class="finish"><div class="t">Durch! 💪</div><div class="s">Alle Sätze abgehakt – stark gemacht.</div></div>
  <main id="list"></main>
  <div class="footnote">Offline nutzbar · Fortschritt wird auf diesem Gerät gespeichert.<br>Tipp: mit „Sichern" einen Code erzeugen – damit geht nichts verloren.<br>Erstellt mit Claude aus Robins Trainingsplan.</div>
  <div class="tools">
    <button class="tbtn2" id="backup">Sichern</button>
    <button class="tbtn2" id="restore">Laden</button>
    <button class="tbtn2" id="reset">Zurücksetzen</button>
  </div>
</div>

<div class="dock"><div class="dockinner">
  <div class="trow">
    <div class="timeval" id="tdisp">1:30</div>
    <div class="tlab">Pausen-Timer</div>
    <button class="tbtn tmain primary" id="tmain">Start</button>
  </div>
  <div class="tpreset" id="tpreset">
    <button class="tbtn" data-s="60">60 s</button>
    <button class="tbtn sel" data-s="90">90 s</button>
    <button class="tbtn" data-s="120">2 min</button>
  </div>
</div></div>

<script>
const EX = [{"name": "Trizepsdrücken", "muscle": "Trizeps", "sets": 3, "equip": "Wenn kein Kabelturm verfügbar ist: schulterbreites Bankdrücken", "tips": ["Ellenbogen nicht nach außen führen, sondern so knapp wie möglich am Körper vorbei", "3 Sätze à 10 Wiederholungen", "Relativ schweres Gewicht", "Immer eine Wiederholung im Tank lassen – außer im letzten Satz, der geht bis zum Ende", "Ausreichend Zeit zwischen den Sätzen lassen, da es ein schwerer Lift ist"]}, {"name": "Strict Curls", "muscle": "Bizeps", "sets": 3, "equip": "Mit Rücken an der Wand, keine Kurzhanteln", "tips": ["Gleiche Regeln wie beim Trizepsdrücken", "Schweres Gewicht", "3 Sätze à 10 Wiederholungen", "Eine Wiederholung im Tank lassen – außer im letzten Satz"]}, {"name": "Trizeps hinter dem Kopf", "muscle": "Trizeps · einarmig", "sets": 3, "equip": "Bevorzugt am Kabelturm, alternativ Kurzhantel", "tips": ["3 Sätze à 15–20 Wiederholungen", "Es soll richtig brennen", "Ellenbogen möglichst ruhig halten, ca. 45° nach außen", "Keine Pause beim Armwechsel", "Jeden Satz bis zum Versagen", "Optional mit dem freien Arm unterstützen, vor allem im letzten Satz"]}, {"name": "Spider Curls", "muscle": "Bizeps", "sets": 3, "equip": "Bank ca. 45°, Kurzhanteln", "tips": ["3 Sätze à 15–20 Wiederholungen", "Kurze Pausen, Gewicht ggf. im 2. oder 3. Satz reduzieren", "Jeden Satz bis zum Versagen", "Optional Oberkörper nach vorne als Drop-Set nutzen"]}, {"name": "Hammercurls", "muscle": "Bizeps · Unterarm", "sets": 2, "equip": "Gerne am Kabelturm", "tips": ["2 Sätze", "Startgewicht für ca. 8 Wiederholungen", "4 Drops pro Satz", "Beispiel: 20 kg → 15 kg → 10 kg → 7,5 kg", "Zwischen den Sätzen etwas mehr Pause"]}, {"name": "Dead Hang", "muscle": "Unterarm · Griffkraft", "sets": 4, "equip": "An einer Stange hängen", "tips": ["Erste 3 Sätze: maximal fest greifen, nicht bis zum Versagen", "Letzter Satz: so lange wie möglich halten, ohne maximal zuzudrücken", "⚠ Warnung: Starker Unterarmmuskelkater möglich"]}];
const KEY='sawx_v2';
let state=EX.map(e=>Array(e.sets).fill(false));
try{const s=localStorage.getItem(KEY);if(s){const p=JSON.parse(s);
  if(Array.isArray(p)&&p.length===EX.length)state=p.map((a,i)=>{const arr=Array(EX[i].sets).fill(false);
    if(Array.isArray(a))a.forEach((v,j)=>{if(j<arr.length)arr[j]=!!v;});return arr;});}}catch(e){}
function save(){try{localStorage.setItem(KEY,JSON.stringify(state));}catch(e){}}
const TICK='<svg class="tick" viewBox="0 0 24 24"><path d="M4 12.5 L10 18.5 L20 6"/></svg>';

/* ---------- vector exercise animations (canvas) ---------- */
const C={ink:'#f3f2e6',acc:'#c8ff3c',wall:'#4e5242'};
const VB=340;
function Pt(o,L,a){const r=a*Math.PI/180;return [o[0]+L*Math.cos(r),o[1]+L*Math.sin(r)];}
function ln(x,p1,p2,c,w){x.strokeStyle=c;x.lineWidth=w;x.lineCap='round';x.beginPath();x.moveTo(p1[0],p1[1]);x.lineTo(p2[0],p2[1]);x.stroke();}
function dt(x,p,r,c){x.fillStyle=c;x.beginPath();x.arc(p[0],p[1],r,0,7);x.fill();}
function rg(x,c0,r,c,w){x.strokeStyle=c;x.lineWidth=w;x.beginPath();x.arc(c0[0],c0[1],r,0,7);x.stroke();}
function db(x,c,col,vert,sc){sc=sc||1;const pl=12*sc,gap=9*sc,th=7*sc;x.fillStyle=col;
  if(vert){x.fillRect(c[0]-th,c[1]-gap-pl,2*th,pl);x.fillRect(c[0]-th,c[1]+gap,2*th,pl);ln(x,[c[0],c[1]-gap],[c[0],c[1]+gap],col,6);}
  else{x.fillRect(c[0]-gap-pl,c[1]-th,pl,2*th);x.fillRect(c[0]+gap,c[1]-th,pl,2*th);ln(x,[c[0]-gap,c[1]],[c[0]+gap,c[1]],col,6);}}
const SCENES=[
 (x,t)=>{const cx=150,sh=[cx,98],hip=[cx,184];
   ln(x,[cx+2,8],[cx+2,60],C.wall,4);rg(x,[cx,64],26,C.ink,8);ln(x,sh,hip,C.ink,9);
   ln(x,hip,[cx-20,262],C.ink,9);ln(x,hip,[cx+30,262],C.ink,9);
   const el=[cx+10,150];ln(x,sh,el,C.acc,11);const a=-120+210*t,w=Pt(el,56,a);ln(x,el,w,C.ink,9);
   ln(x,[w[0]-26,w[1]],[w[0]+26,w[1]],C.ink,7);dt(x,[w[0]-26,w[1]],6,C.ink);dt(x,[w[0]+26,w[1]],6,C.ink);},
 (x,t)=>{const cx=165,sh=[cx,98],hip=[cx,184];
   ln(x,[cx-44,30],[cx-44,250],C.wall,5);rg(x,[cx,64],26,C.ink,8);ln(x,sh,hip,C.ink,9);
   ln(x,hip,[cx-20,262],C.ink,9);ln(x,hip,[cx+30,262],C.ink,9);
   const el=[cx-6,150];ln(x,sh,el,C.acc,11);const a=90-150*t,w=Pt(el,58,a);ln(x,el,w,C.ink,9);
   ln(x,[w[0]-24,w[1]-6],[w[0]+24,w[1]+6],C.ink,7);},
 (x,t)=>{const cx=150,sh=[cx,112],hip=[cx,196];
   rg(x,[cx,78],26,C.ink,8);ln(x,sh,hip,C.ink,9);
   ln(x,hip,[cx-20,274],C.ink,9);ln(x,hip,[cx+30,274],C.ink,9);
   const el=[cx+6,58];ln(x,sh,el,C.acc,11);const a=135+135*t,w=Pt(el,50,a);ln(x,el,w,C.ink,9);db(x,w,C.ink,false,0.9);},
 (x,t)=>{ln(x,[40,250],[210,95],C.wall,10);ln(x,[210,95],[210,150],C.wall,5);ln(x,[60,250],[60,290],C.wall,5);
   rg(x,[196,92],22,C.ink,8);const chest=[150,130],hip=[96,168];ln(x,chest,hip,C.ink,9);
   ln(x,hip,[70,210],C.ink,9);ln(x,hip,[80,214],C.ink,9);
   const sh=[158,126],el=[168,172];ln(x,sh,el,C.acc,11);const a=90-135*t,w=Pt(el,52,a);ln(x,el,w,C.ink,9);db(x,w,C.ink,false,0.85);},
 (x,t)=>{const cx=150,sh=[cx,98],hip=[cx,184];
   rg(x,[cx,64],26,C.ink,8);ln(x,sh,hip,C.ink,9);
   ln(x,hip,[cx-20,262],C.ink,9);ln(x,hip,[cx+30,262],C.ink,9);
   const el=[cx+8,150];ln(x,sh,el,C.acc,11);const a=90-150*t,w=Pt(el,56,a);ln(x,el,w,C.ink,9);db(x,w,C.ink,true,0.9);},
 (x,t)=>{const cx=150,bob=Math.sin(t*Math.PI)*-12;ln(x,[60,40],[240,40],C.wall,8);
   const sh=[cx,144+bob],elL=[cx-22,92+bob],elR=[cx+22,92+bob];
   ln(x,sh,elL,C.ink,9);ln(x,sh,elR,C.ink,9);ln(x,elL,[cx-26,40],C.acc,11);ln(x,elR,[cx+26,40],C.acc,11);
   rg(x,[cx,110+bob],26,C.ink,8);ln(x,sh,[cx,226+bob],C.ink,9);
   ln(x,[cx,226+bob],[cx-14,300+bob],C.ink,9);ln(x,[cx,226+bob],[cx+14,300+bob],C.ink,9);},
];

function render(){
  const list=document.getElementById('list');
  list.innerHTML=EX.map((e,i)=>{
    const tips=e.tips.map(t=>{const w=t.indexOf('⚠')===0;return `<li class="${w?'warn':''}">${w?t.replace('⚠ ',''):t}</li>`;}).join('');
    const sets=state[i].map((on,j)=>`<div class="setbtn ${on?'on':''}" data-e="${i}" data-s="${j}">${TICK}Satz ${j+1}</div>`).join('');
    return `<section class="card" id="card-${i}">
      <div class="chead">
        <div class="badge"><canvas class="anim" data-ex="${i}" aria-label="${e.name} Animation"></canvas></div>
        <div class="titleblock"><div class="exno">Übung ${i+1}</div><div class="exname">${e.name}</div><span class="chip">${e.muscle}</span></div>
      </div>
      <div class="equip">${e.equip}</div>
      <ul class="tips">${tips}</ul>
      <div class="sets">${sets}</div>
      <div class="donebar">${TICK.replace('class="tick"','class="tick" style="width:15px;height:15px"')} Übung erledigt</div>
    </section>`;
  }).join('');
  list.querySelectorAll('.setbtn').forEach(b=>b.addEventListener('click',()=>{
    const i=+b.dataset.e,j=+b.dataset.s;const wasOn=state[i][j];const target=wasOn?j:j+1;
    for(let k=0;k<state[i].length;k++)state[i][k]=k<target;save();refresh();
    if(!wasOn&&navigator.vibrate)navigator.vibrate(12);}));
  refresh();setupAnims();
}
function refresh(){
  let done=0,tot=0;
  EX.forEach((e,i)=>{tot+=e.sets;const d=state[i].filter(Boolean).length;done+=d;
    const card=document.getElementById('card-'+i);card.classList.toggle('done',d===e.sets);
    card.querySelectorAll('.setbtn').forEach((b,j)=>b.classList.toggle('on',state[i][j]));});
  document.getElementById('pdone').textContent=done;document.getElementById('ptot').textContent=tot;
  document.getElementById('pfill').style.width=(tot?(done/tot*100):0)+'%';
  document.getElementById('finish').classList.toggle('show',tot>0&&done===tot);
}
document.getElementById('reset').addEventListener('click',()=>{
  if(confirm('Allen Fortschritt zurücksetzen?')){state=EX.map(e=>Array(e.sets).fill(false));save();refresh();
    window.scrollTo({top:0,behavior:'smooth'});}});
function _restore(ns){state=ns;save();refresh();}
document.getElementById('backup').addEventListener('click',()=>{
  let code;try{code=btoa(unescape(encodeURIComponent(JSON.stringify(state))));}catch(e){code=JSON.stringify(state);}
  if(navigator.clipboard&&navigator.clipboard.writeText)navigator.clipboard.writeText(code).catch(()=>{});
  prompt('Sicherungscode – kopieren & sicher aufbewahren (zum Wiederherstellen unter „Laden" einfügen):',code);});
document.getElementById('restore').addEventListener('click',()=>{
  const code=prompt('Sicherungscode einfügen:');if(!code)return;
  try{const p=JSON.parse(decodeURIComponent(escape(atob(code.trim()))));
    if(Array.isArray(p)&&p.length===EX.length){_restore(p.map((a,i)=>{const arr=Array(EX[i].sets).fill(false);
      if(Array.isArray(a))a.forEach((v,j)=>{if(j<arr.length)arr[j]=!!v;});return arr;}));return;}throw 0;
  }catch(e){alert('Code ungültig.');}});

/* animation loop */
let anims=[];
function setupAnims(){
  anims=[];
  const reduce=window.matchMedia&&window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  document.querySelectorAll('canvas.anim').forEach(cv=>{
    const i=+cv.dataset.ex,dpr=Math.min(2,window.devicePixelRatio||1),s=cv.clientWidth||104;
    cv.width=Math.round(s*dpr);cv.height=Math.round(s*dpr);
    const x=cv.getContext('2d');x.scale(cv.width/VB,cv.height/VB);
    anims.push({x,fn:SCENES[i]});
    if(reduce){x.clearRect(0,0,VB,VB);SCENES[i](x,1);}
  });
  if(reduce)return;
  if(!setupAnims._raf)setupAnims._raf=requestAnimationFrame(loop);
}
const PERIOD=1900;
function loop(now){
  const t=(1-Math.cos(2*Math.PI*((now%PERIOD)/PERIOD)))/2;
  for(const a of anims){a.x.clearRect(0,0,VB,VB);a.fn(a.x,t);}
  setupAnims._raf=requestAnimationFrame(loop);
}

/* ---------- rest timer ---------- */
let dur=90,left=90,running=false,tid=null;
const tdisp=document.getElementById('tdisp'),tmain=document.getElementById('tmain');
function fmt(s){return Math.floor(s/60)+':'+String(s%60).padStart(2,'0');}
function paint(){tdisp.textContent=fmt(left);tdisp.classList.toggle('run',running);}
function setMain(){tmain.textContent=running?'Stop':'Start';}
function stopT(){running=false;clearInterval(tid);tid=null;left=dur;paint();setMain();}
function beep(){try{const a=new(window.AudioContext||window.webkitAudioContext)();const o=a.createOscillator(),g=a.createGain();
  o.connect(g);g.connect(a.destination);o.type='sine';o.frequency.value=880;
  g.gain.setValueAtTime(.001,a.currentTime);g.gain.exponentialRampToValueAtTime(.4,a.currentTime+.02);
  g.gain.exponentialRampToValueAtTime(.001,a.currentTime+.6);o.start();o.stop(a.currentTime+.62);}catch(e){}
  if(navigator.vibrate)navigator.vibrate([120,60,120]);}
function tick(){left--;paint();if(left<=0){clearInterval(tid);tid=null;running=false;beep();left=dur;setMain();paint();}}
tmain.addEventListener('click',()=>{if(running){stopT();}else{running=true;left=left>0?left:dur;setMain();paint();tid=setInterval(tick,1000);}});
document.getElementById('tpreset').addEventListener('click',e=>{const b=e.target.closest('.tbtn');if(!b)return;
  document.querySelectorAll('#tpreset .tbtn').forEach(x=>x.classList.remove('sel'));b.classList.add('sel');
  dur=+b.dataset.s;left=dur;if(running){clearInterval(tid);tid=setInterval(tick,1000);}paint();});

paint();setMain();render();
window.addEventListener('orientationchange',()=>setTimeout(setupAnims,300));
</script>
</body>
</html>
